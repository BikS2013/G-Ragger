{
  "name": "geminirag",
  "version": "1.0.0",
  "description": "TypeScript CLI tool for workspace-based document management and semantic search using Gemini File Search API",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "geminirag": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "tsx test_scripts/test-config.ts && tsx test_scripts/test-registry.ts"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@mozilla/readability": "^0.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "jsdom": "^29.0.2",
    "mime-types": "^2.1.35",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "uuid": "^10.0.0",
    "youtube-transcript-plus": "^1.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/mime-types": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
